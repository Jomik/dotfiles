{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(jj:*)",
      "Bash(git:*)",
      "Bash(just:*)",
      "Bash(cargo:*)",
      "Bash(mise run:*)",
      "Bash(pnpm run:*)",
      "Bash(npm run:*)",
      "Bash(uv run:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh repo view:*)",
      "Bash(gh search:*)",
      "Bash(gh label list:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "LSP"
    ],
    "ask": [
      "Bash(cargo install:*)",
      "Bash(cargo publish:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git branch -D:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/check-jj.sh",
            "timeout": 5,
            "statusMessage": "Checking VCS..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"IMPORTANT: You MUST check if any available skill applies to the user request BEFORE responding or taking any action. If a skill applies, invoke it with the Skill tool first. This is not optional. design: Use when the user wants to build, add, fix, or change something in the codebase. Single entry point — detects what exists and produces specs and plans. implementing: Use when executing implementation plans. code-review: Use when reviewing code before merge.\"}}'",
            "async": false
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "autoUpdatesChannel": "stable",
  "autoDreamEnabled": false
}
